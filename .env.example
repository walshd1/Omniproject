# OmniProject — example environment
# Copy to `.env` and fill in. NOTHING here is required to boot: with no config
# the gateway runs in stateless DEMO mode (sample data, admin session, no SSO).
# Wire the sections you need. Never commit your real .env.

# ───────────────────────────── Core / runtime ──────────────────────────────
# PORT=8080
# NODE_ENV=production              # enables prod guardrails (stateless-only, etc.)
# SESSION_SECRET=                  # REQUIRED in prod — long random string; signs cookies
# PUBLIC_URL=https://omni.example.com   # external origin (OIDC redirect URIs)
# STATIC_DIR=/app/public           # single-container mode: serve the built SPA from here

# ──────────────────────────── Identity (OIDC) ──────────────────────────────
# Leave all unset to run in demo mode (no SSO). Set these to enforce login.
# OIDC_ISSUER_URL=https://auth.example.com/realms/omni
# OIDC_CLIENT_ID=omniproject
# OIDC_CLIENT_SECRET=
# OIDC_SCOPE=openid profile email
# OIDC_AUDIENCE=                   # if the token aud differs from the client id
# OIDC_SKIP_TOKEN_VERIFY=false     # escape hatch ONLY — keep false in prod

# ─────────────────────────── RBAC role mapping ─────────────────────────────
# Comma lists of IdP role/group claims → OmniProject roles. Unmatched users get
# OIDC_DEFAULT_ROLE. Demo sessions are always admin.
# OIDC_ADMIN_ROLES=omni-admins,platform-admins
# OIDC_MANAGER_ROLES=pmo,programme-managers
# OIDC_CONTRIBUTOR_ROLES=
# OIDC_VIEWER_ROLES=stakeholders
# OIDC_DEFAULT_ROLE=contributor

# ─────────────────────────────── broker ────────────────────────────────────
# The single endpoint OmniProject brokers ALL backend reads/writes through.
# The broker is pluggable behind a published contract (docs/CONTRACT.md); n8n is
# the reference broker that ships by default (see docs/BROKER.md).
# BROKER_URL=https://n8n.example.com/webhook/omniproject
#   ^ the broker-neutral name. N8N_WEBHOOK_URL is accepted as a DEPRECATED
#     backwards-compatible alias (pre-0.2.0) if BROKER_URL is unset.
# BROKER_URLS=https://n8n-1.example.com/webhook/omniproject,https://n8n-2.example.com/webhook/omniproject
#   ^ optional: a comma-separated POOL of n8n instances. When set, the broker
#     load-balances across them (round-robin) with connection-level failover,
#     overriding BROKER_URL. For horizontal n8n scale (use n8n queue mode too).
# BROKER_PSK=                      # OPTIONAL app-layer broker encryption — a FALLBACK BELOW TLS.
#   ^ prefer TLS (https:// BROKER_URL) — it also authenticates the broker's cert.
#     Set this only when TLS is genuinely unavailable on the hop: a shared
#     high-entropy key (both ends) that AES-256-GCM-encrypts the whole request
#     envelope INCLUDING the forwarded auth token, so a packet capture sees only
#     ciphertext. Caveats: no forward secrecy, no peer auth, metadata still leaks.
#     The broker MUST implement the matching crypto (see docs/BROKER-HTTP-BINDING.md §2a).
# BACKEND_SOURCE=all               # routing hint (all | jira | openproject | …)
# CAPABILITIES=                    # pin domains (issues,scheduling,portfolio,…) to skip probing

# ───────────────────────────── AI (optional) ───────────────────────────────
# AI_PROVIDER=none                 # none | openai | anthropic | ollama | openrouter
# AI_MODEL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_URL=http://localhost:11434

# ───────────────────── Real-time notifications + bus ───────────────────────
# NOTIFY_INGEST_SECRET=            # enables POST /api/notifications/ingest (constant-time checked)

# ─────────────────── Multi-replica / horizontal scale ──────────────────────
# REDIS_URL=                       # ONE knob for fleet fan-out. With it (+ the optional
#   ^ clients below) notifications, the admin live broker-log, AND rate-limit counters
#     become cross-replica. Without it each replica runs correctly but in isolation.
#     Install the runtime-optional clients:
#         pnpm --filter @workspace/api-server add ioredis rate-limit-redis
#     Verify via GET /api/setup/status -> scale.{notifyBus,brokerLogBus,rateLimit}="redis".
#     Falls back to per-replica (logged once) if unset or clients absent. See docs/ops/MULTI-REPLICA.md.
# REPLICA_ID=                      # optional stable label for THIS replica in the broker log
#   ^ (defaults to a random short id per process).

# ──────────────────────────────── Audit ────────────────────────────────────
# AUDIT_LEVEL=off                  # off | writes | all
# AUDIT_HTTP_URL=                  # ship NDJSON audit lines to a logging server
# AUDIT_HTTP_TOKEN=
# AUDIT_BATCH=50
# AUDIT_FLUSH_MS=2000

# ──────────────────────────── Rate limiting ────────────────────────────────
# RATE_LIMIT_DISABLED=false        # true only behind your own gateway/WAF

# ─────────────────────── Config durability (optional) ──────────────────────
# CONFIG_STORE_FILE=/data/omni-config.json   # persist environments + rollback history
# DEV_PERSIST_FILE=                # STATEFUL developer mode ONLY (ignored in production)

# ════════════════════ PREMIUM — licence VERIFICATION (every deployment) ═════
# PRE-COMMUNITY: premium is FREE to run — enforcement is dormant, not removed.
# Every premium feature is granted by default; the vars below only matter once
# enforcement is switched back on. See LICENSING.md.
# PREMIUM_ENFORCEMENT=on           # restore the paywall (default: off = all features free)
# LICENSE_PUBLIC_KEY=              # the vendor's Ed25519 public key (PEM or base64)
# LICENSE_KEY=                     # the signed licence token issued to this deployment
# LICENSE_DEV_FEATURES=            # non-prod only: "all" or a feature list; ignored in prod

# ═══════════════ PREMIUM — licence ISSUING (VENDOR instance ONLY) ═══════════
# Only on the instance that mints licences (scripts/mint-license.ts). NEVER ship
# LICENSE_PRIVATE_KEY to a customer deployment. (Payment-provider plumbing was
# removed during the pre-community period — see LICENSING.md.)
# LICENSE_PRIVATE_KEY=             # Ed25519 issuing key — mints customer licences

# ───────────── PREMIUM — branding / nomenclature / webhook seeds ────────────
# Optional seed values (also editable in-app under Settings → Premium overlay).
# BRAND_APP_NAME=
# BRAND_SHORT_NAME=
# BRAND_LOGO_URL=
# BRAND_PRIMARY_COLOR=#2563eb
# BRAND_LOGIN_HEADING=
# BRAND_FOOTER_TEXT=
# BRAND_SUPPORT_URL=
# LABEL_OVERRIDES={"nav.projects":"Engagements"}
# WEBHOOKS=[{"url":"https://hooks.example.com/omni","secret":"…","events":["*"]}]

# ───────────────────────── Dev / test / stress ─────────────────────────────
# DEMO_SCALE_PROJECTS=200
# DEMO_SCALE_ISSUES=10
# STRESS_USERS=2000
# STRESS_REQS=3
# STRESS_CONCURRENCY=100
# STRESS_MAX_ERROR_RATE=0.01
# OMNI_API_BASE=http://localhost:5000
# OPENPROJECT_LIVE_URL=            # live integration cert (skipped if unset)
# OPENPROJECT_TOKEN=

# ═══════════ DOCKER COMPOSE — local standalone stack (docker-compose.standalone.yml)
# These back the bundled Traefik + Authentik + n8n + Ollama stack. Compose
# FAILS FAST (won't start) if a required one is missing — that's intentional.
# Full bootstrap (mkcert TLS, /etc/hosts, Authentik app): docs/DEPLOY-LOCAL.md
#
# Required:
# SESSION_SECRET=                  # long random string; signs the session cookie
# OIDC_CLIENT_SECRET=              # the "omniproject" OIDC client secret from Authentik
# AUTHENTIK_PG_PASSWORD=           # Authentik's Postgres password
# AUTHENTIK_SECRET_KEY=            # Authentik secret key (50+ random chars)
#
# Traefik dashboard auth (htpasswd, bcrypt). Generate the line with:
#   htpasswd -nbB admin 'your-password'      ->  admin:$2y$05$abc...
# IMPORTANT: in a .env FILE, Compose interpolates values, so EVERY '$' must be
#    DOUBLED to '$$'. The single-$ form only works when exported in your shell.
#    So paste it here with doubled $$, e.g.:
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$abc...defGHIjklMNOpqrSTUvwx
#    (or keep it OUT of .env and `export TRAEFIK_DASHBOARD_AUTH='admin:$2y$05$...'`
#     with a single $ in your shell before running compose.)
#
# Optional (have sensible defaults): OIDC_CLIENT_ID=omniproject, AI_PROVIDER,
# AI_MODEL, OPENROUTER_API_KEY.

# ═══════════ DOCKER COMPOSE — enterprise / BYO profile (docker-compose.enterprise.yml)
# Required (compose fails fast without them):
# PUBLIC_URL=https://omni.example.com   # external HTTPS origin (Secure cookies need https)
# OIDC_ISSUER_URL=https://your-idp.example.com/...   # your existing IdP (https)
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# SESSION_SECRET=
# Optional: BROKER_URL, N8N_PUBLIC_URL, PLANE_INSTANCE_URL, OPENPROJECT_INSTANCE_URL, AI_*
