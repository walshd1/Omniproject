{
  "id": "budget-plans",
  "label": "Budget plans",
  "hint": "Planned budget by period and project. Edit the plans in Settings → Budget plans.",
  "panels": [
    {
      "id": "budget-by-year-chart",
      "kind": "chart",
      "title": "Budget by year",
      "span": 12,
