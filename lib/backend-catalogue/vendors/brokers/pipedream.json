{
  "build": "component-template",
  "capabilities": {
    "eventsInbound": true,
    "eventsOutbound": true,
    "managedAuth": true,
    "selfHostable": false,
    "synchronous": true
  },
  "docsUrl": "https://pipedream.com/docs/",
  "hosted": true,
  "id": "pipedream",
  "keyFormat": {
    "env": [
      "BROKER_PSK"
    ],
    "header": "X-Omni-Sig",
    "pattern": "^.{16,}$",
    "scheme": "psk"
  },
  "kind": "code-first",
  "label": "Pipedream",
  "notes": "Code-first components on an HTTP source can `$respond()` synchronously — a strong fit for the binding.",
  "transports": [
    "http"
  ]
}
