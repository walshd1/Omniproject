# Fully self-hosted — docker-compose.slim.yml with OmniProject's BUILT-IN DATABASE as the system of record.
# No external backend (Jira/ADO) and no external DB service: the first-party encrypted, hash-chained OmniStore
# holds everything, persisted to a file on the host. This is the "batteries-included" self-hosted topology —
# pair it with the "Self-hosted Scrum" app preset in the setup wizard for a zero-external-dependency instance.
SETTINGS_PRESET=regulated-selfhost
# The built-in store IS the system of record. `omnistore` = the first-party encrypted, tamper-evident event log.
BUILTIN_BROKER=omnistore
# Durable path for the sealed store. WITHOUT this the store runs IN MEMORY and is lost on restart — always set
# it (and back the file up) for a real deployment. (Alternatively BUILTIN_BROKER=sidecar + SQL_SIDECAR_URL to
# use a SQL sidecar container instead of the file-backed store.)
OMNISTORE_FILE=/data/omnistore.sealed
AI_PROVIDER=none            # or 'ollama' for a LOCAL model with no egress
SESSION_SECRET=
