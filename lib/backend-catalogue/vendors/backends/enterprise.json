{
  "actions": {
    "create_issue": {
      "body": "={{ JSON.stringify({ title: $json.body.payload.title, description: $json.body.payload.description }) }}",
      "method": "POST",
      "url": "={{ $env.BACKBONE_BASE_URL }}/projects/{{ $json.body.payload.projectId }}/items"
    },
    "delete_issue": {
      "method": "DELETE",
      "url": "={{ $env.BACKBONE_BASE_URL }}/items/{{ $json.body.payload.issueId }}"
    },
    "list_issues": {
      "method": "GET",
      "url": "={{ $env.BACKBONE_BASE_URL }}/projects/{{ $json.body.payload.projectId }}/items"
    },
    "list_projects": {
      "method": "GET",
      "url": "={{ $env.BACKBONE_BASE_URL }}/projects"
    },
    "update_issue": {
      "body": "={{ JSON.stringify({ title: $json.body.payload.title }) }}",
      "method": "PATCH",
      "url": "={{ $env.BACKBONE_BASE_URL }}/items/{{ $json.body.payload.issueId }}"
    }
  },
  "authHeader": "",
  "capabilities": {
    "baseline": false,
    "blockers": false,
    "financials": false,
    "history": false,
    "issues": true,
    "portfolio": false,
    "raid": false,
    "resources": false,
    "scheduling": true
  },
  "credentialType": "httpHeaderAuth",
  "docsUrl": "https://docs.n8n.io/integrations/builtin/core-nodes/n8n-nodes-base.httprequest/",
  "id": "enterprise",
  "label": "Enterprise backbone (Capita / custom REST / OData / SOAP)",
  "notes": "A starting template for bespoke corporate systems — Capita platforms, ESB/SOA gateways, mainframe-fronting REST. Auth via n8n's generic Header-Auth/OAuth2 credential. For SOAP backbones set the HTTP node to send XML (or use a SOAP community node); for message buses (IBM MQ, Kafka, RabbitMQ) trigger via the matching n8n node and call back through /api/notifications/ingest or a follow-up action.",
  "requiredEnv": [
    "BACKBONE_BASE_URL"
  ],
  "verification": "experimental",
  "via": "HTTP + n8n credential — point at your endpoint"
}
