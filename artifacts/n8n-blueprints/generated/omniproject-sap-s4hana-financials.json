    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SAP_S4_URL }}/sap/opu/odata/sap/API_PROJECTACTUALCOSTS_CDS/I_ProjectActualCosts?$filter=WBSElementInternalID eq '{{ $json.body.payload.projectId }}'&$format=json",
        "sendHeaders": false,
        "headerParameters": {
          "parameters": []
        },
