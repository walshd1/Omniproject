{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omniproject.dev/vendors/output.schema.json",
  "title": "OmniProject output vendor",
  "description": "An outward interface that exposes portfolio data/events. One file per vendor under vendors/outputs/<id>.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "route", "kind", "capabilities", "tools"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "label": { "type": "string" },
    "route": { "type": "string" },
    "kind": { "enum": ["read-api", "bi-feed", "agent-api", "export", "metrics", "events-out", "events-in", "batch-egress", "calendar"] },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readOnly", "streaming", "auth"],
      "properties": {
        "readOnly": { "type": "boolean" },
        "streaming": { "type": "boolean" },
        "auth": { "enum": ["session", "api-token", "session-or-token", "hmac", "user-action", "oauth2"] }
      }
    },
    "transports": {
      "type": "array",
      "description": "Which connection methods OmniProject offers for this output (e.g. a calendar reachable via its REST API or an MCP server). Omitted when the output has a single implicit transport (its route).",
      "items": { "enum": ["api", "mcp", "ical-feed"] }
    },
    "tools": { "type": "array", "items": { "type": "string" } },
    "methodologies": { "type": "array", "description": "Methodology TAGS this output belongs to (\"*\" or omitted = neutral / all). Admin/PMO-editable.", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
