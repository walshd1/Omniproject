{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the OmniProject gateway /api/metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "OmniProject Gateway — RED / SLO",
  "uid": "omniproject-gateway-red",
  "tags": ["omniproject", "gateway", "slo"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability (5m SLI)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.99 }, { "color": "green", "value": 0.999 } ] } } },
      "targets": [ { "refId": "A", "expr": "omniproject:availability:ratio5m", "legendFormat": "availability" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p99 latency (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 2000 } ] } } },
      "targets": [ { "refId": "A", "expr": "omniproject:http_latency_p99_ms:5m", "legendFormat": "p99 ms" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "In-flight requests",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [ { "refId": "A", "expr": "max(omniproject_http_in_flight)", "legendFormat": "in-flight" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Request rate (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [ { "refId": "A", "expr": "omniproject:http_requests:rate5m", "legendFormat": "req/s" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP request rate by status class",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [ { "refId": "A", "expr": "sum by (status) (rate(omniproject_http_requests_total[5m]))", "legendFormat": "{{status}}" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx error ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 } },
      "targets": [ { "refId": "A", "expr": "sum(rate(omniproject_http_errors_total[5m])) / clamp_min(sum(rate(omniproject_http_requests_total[5m])), 1)", "legendFormat": "5xx ratio" } ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request latency percentiles (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(omniproject_http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(omniproject_http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(omniproject_http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Broker calls by result",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [ { "refId": "A", "expr": "sum by (result) (rate(omniproject_broker_requests_total[5m]))", "legendFormat": "{{result}}" } ]
    }
  ]
}
