# OmniProject — example environment
# Copy to `.env` and fill in. NOTHING here is required to boot: with no config
# the gateway runs in stateless DEMO mode (sample data, admin session, no SSO).
# Wire the sections you need. Never commit your real .env.

# ───────────────────────────── Core / runtime ──────────────────────────────
# PORT=8080
# NODE_ENV=production              # enables prod guardrails (stateless-only, etc.)
# SESSION_SECRET=                  # REQUIRED in prod — long random string; signs cookies
# PUBLIC_URL=https://omni.example.com   # external origin (OIDC redirect URIs)
# STATIC_DIR=/app/public           # single-container mode: serve the built SPA from here

# ──────────────────────────── Identity (OIDC) ──────────────────────────────
# Leave all unset to run in demo mode (no SSO). Set these to enforce login.
# OIDC_ISSUER_URL=https://auth.example.com/realms/omni
# OIDC_CLIENT_ID=omniproject
# OIDC_CLIENT_SECRET=
# OIDC_SCOPE=openid profile email
# OIDC_AUDIENCE=                   # if the token aud differs from the client id
# OIDC_SKIP_TOKEN_VERIFY=false     # escape hatch ONLY — keep false in prod

# ─────────────────────────── RBAC role mapping ─────────────────────────────
# Comma lists of IdP role/group claims → OmniProject roles. Unmatched users get
# OIDC_DEFAULT_ROLE. Demo sessions are always admin.
# OIDC_ADMIN_ROLES=omni-admins,platform-admins
# OIDC_MANAGER_ROLES=pmo,programme-managers
# OIDC_CONTRIBUTOR_ROLES=
# OIDC_VIEWER_ROLES=stakeholders
# OIDC_DEFAULT_ROLE=contributor

# ─────────────────────────────── broker ────────────────────────────────────
# The single endpoint OmniProject brokers ALL backend reads/writes through.
# n8n is the default broker behind a stable internal seam (see docs/BROKER.md).
# BROKER_URL=https://n8n.example.com/webhook/omniproject
# N8N_WEBHOOK_URL=               # deprecated alias of BROKER_URL (still honoured)
# BACKEND_SOURCE=all               # routing hint (all | jira | openproject | …)
# CAPABILITIES=                    # pin domains (issues,scheduling,portfolio,…) to skip probing

# ───────────────────────────── AI (optional) ───────────────────────────────
# AI_PROVIDER=none                 # none | openai | anthropic | ollama | openrouter
# AI_MODEL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_URL=http://localhost:11434

# ───────────────────── Real-time notifications + bus ───────────────────────
# NOTIFY_INGEST_SECRET=            # enables POST /api/notifications/ingest (constant-time checked)
# REDIS_URL=                       # set (+ `pnpm add ioredis`) to fan SSE out across replicas

# ──────────────────────────────── Audit ────────────────────────────────────
# AUDIT_LEVEL=off                  # off | writes | all
# AUDIT_HTTP_URL=                  # ship NDJSON audit lines to a logging server
# AUDIT_HTTP_TOKEN=
# AUDIT_BATCH=50
# AUDIT_FLUSH_MS=2000

# ──────────────────────────── Rate limiting ────────────────────────────────
# RATE_LIMIT_DISABLED=false        # true only behind your own gateway/WAF

# ─────────────────────── Config durability (optional) ──────────────────────
# CONFIG_STORE_FILE=/data/omni-config.json   # persist environments + rollback history
# DEV_PERSIST_FILE=                # STATEFUL developer mode ONLY (ignored in production)

# ════════════════════ PREMIUM — licence VERIFICATION (every deployment) ═════
# Set these on any deployment that should unlock premium features.
# LICENSE_PUBLIC_KEY=              # the vendor's Ed25519 public key (PEM or base64)
# LICENSE_KEY=                     # the signed licence token issued to this deployment
# LICENSE_DEV_FEATURES=            # non-prod only: "all" or a feature list; ignored in prod

# ═══════════════ PREMIUM — sales / fulfilment (VENDOR instance ONLY) ════════
# These belong ONLY on the instance that processes your payments. NEVER ship
# LICENSE_PRIVATE_KEY to a customer deployment.
# LICENSE_PRIVATE_KEY=             # Ed25519 issuing key — mints customer licences
# LICENSE_PRODUCTS={"price_pro":{"tier":"pro","features":["branding","labels"],"days":365}}
# LICENSE_FULFILLMENT_URL=         # n8n webhook that emails the buyer their key
# LICENSE_FULFILLMENT_SECRET=      # shared secret to HMAC-sign the hand-off
# LICENSE_FROM_EMAIL=licenses@example.com
# STRIPE_WEBHOOK_SECRET=           # verifies POST /api/licensing/stripe
# GUMROAD_WEBHOOK_SECRET=          # shared token for POST /api/licensing/gumroad
# GUMROAD_SELLER_ID=

# ───────────── PREMIUM — branding / nomenclature / webhook seeds ────────────
# Optional seed values (also editable in-app under Settings → Premium overlay).
# BRAND_APP_NAME=
# BRAND_SHORT_NAME=
# BRAND_LOGO_URL=
# BRAND_PRIMARY_COLOR=#2563eb
# BRAND_LOGIN_HEADING=
# BRAND_FOOTER_TEXT=
# BRAND_SUPPORT_URL=
# LABEL_OVERRIDES={"nav.projects":"Engagements"}
# WEBHOOKS=[{"url":"https://hooks.example.com/omni","secret":"…","events":["*"]}]

# ───────────────────────── Dev / test / stress ─────────────────────────────
# DEMO_SCALE_PROJECTS=200
# DEMO_SCALE_ISSUES=10
# STRESS_USERS=2000
# STRESS_REQS=3
# STRESS_CONCURRENCY=100
# STRESS_MAX_ERROR_RATE=0.01
# OMNI_API_BASE=http://localhost:5000
# OPENPROJECT_LIVE_URL=            # live integration cert (skipped if unset)
# OPENPROJECT_TOKEN=
