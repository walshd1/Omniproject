# OmniProject — example environment
# Copy to `.env` and fill in. NOTHING here is required to boot: with no config
# the gateway runs in stateless DEMO mode (sample data, admin session, no SSO).
# Wire the sections you need. Never commit your real .env.

# ───────────────────────────── Core / runtime ──────────────────────────────
# PORT=8080
# NODE_ENV=production              # enables prod guardrails (stateless-only, etc.)
# SESSION_SECRET=                  # REQUIRED in prod — long random string; signs cookies
#
# Deployment profile — tells the gateway your context so its defaults fit, and lets a small
# org relax enterprise couplings BY CHOICE (everything advanced is opt-in regardless):
# DEPLOYMENT_PROFILE=business      # enterprise | business (SME, default) | nonprofit | self-hosted | demo
#   - "self-hosted"/"nonprofit"/"demo": serve plain HTTP on a LAN without breaking sessions,
#     and running without SSO (demo auth) is an accepted choice, not a critical fault.
#   - "business"/"enterprise": assume HTTPS + SSO (today's defaults).
# PUBLIC_TLS=                      # force secure cookies + HSTS on/off, overriding the profile
# ACCEPT_DEMO_AUTH=                # =1 to explicitly accept no-SSO (everyone admin) on any profile
# PUBLIC_URL=https://omni.example.com   # external origin (OIDC redirect URIs)
# STATIC_DIR=/app/public           # single-container mode: serve the built SPA from here

# ──────────────────────────── Identity (OIDC) ──────────────────────────────
# Leave all unset to run in demo mode (no SSO). Set these to enforce login.
# OIDC_ISSUER_URL=https://auth.example.com/realms/omni
# OIDC_CLIENT_ID=omniproject
# OIDC_CLIENT_SECRET=
# OIDC_SCOPE=openid profile email
# OIDC_AUDIENCE=                   # if the token aud differs from the client id
# OIDC_SKIP_TOKEN_VERIFY=false     # escape hatch ONLY — keep false in prod
#
# ── SAML 2.0 SSO (optional; sits ALONGSIDE OIDC behind the same auth seam) ──
# For IdPs that speak SAML rather than OIDC (many ADFS / legacy Entra / Okta setups). The
# gateway is the SAML Service Provider; the IdP asserts identity + group attributes, which map
# onto the SAME fixed roles as OIDC group claims (see "RBAC role mapping" below). SAML is ON
# only when the THREE required vars are set; a PARTIAL config is flagged at boot and stays off.
# The provider library is an OPTIONAL dependency — enable with:
#   pnpm --filter @workspace/api-server add @node-saml/node-saml
# Full provisioning + deprovisioning runbook (Okta / Entra / Google): docs/SSO-SCIM.md
# SAML_IDP_ENTRY_POINT=https://idp.example.com/app/sso/saml   # required: IdP SSO redirect URL
# SAML_IDP_CERT=                   # required: IdP signing cert (PEM, or base64-of-PEM)
# SAML_CALLBACK_URL=               # our ACS URL; defaults to <PUBLIC_URL>/api/auth/saml/callback
# SAML_SP_ENTITY_ID=               # our SP entityID/issuer (defaults to PUBLIC_URL)
# SAML_AUDIENCE=                   # expected assertion audience (defaults to the SP entityID)
# SAML_EMAIL_ATTR=email            # attribute names to read (set to your IdP's URNs if needed)
# SAML_NAME_ATTR=displayName
# SAML_GROUPS_ATTR=groups          # the group attribute → role claims (same map as OIDC)
# SAML_WANT_RESPONSE_SIGNED=false  # also require the <Response> signed (assertions always are)
#
# Maker-checker (four-eyes) — actions listed here need a SECOND admin to approve before they
# apply (proposals at /api/admin/approvals). Wired executors: key.revoke, maintenance.engage.
# DUAL_CONTROL_ACTIONS=key.revoke,maintenance.engage

# Session hardening:
# MAX_SESSIONS_PER_USER=0          # cap concurrent sessions per user (0 = unlimited; newest win)
# SESSION_IDLE_MINUTES=30          # sliding idle timeout
# SESSION_ABSOLUTE_HOURS=8         # hard session lifetime

# ─────────────────── Network — IP allowlist (optional) ─────────────────────
# Restrict access to specific networks (defence in depth behind your ingress/LB).
# Comma-separated IPv4/IPv6 addresses or CIDRs. Empty = allow all. Health probes exempt.
# IP_ALLOWLIST=10.0.0.0/8, 192.168.1.5, 2001:db8::/32
# TRUST_PROXY=0                    # 1 = read client IP from X-Forwarded-For (only behind a trusted proxy)

# ─────────────────────────── RBAC role mapping ─────────────────────────────
# Comma lists of IdP role/group claims → OmniProject roles. Unmatched users get
# OIDC_DEFAULT_ROLE. Demo sessions hold every grant.
#
# Base ladder: viewer < contributor < manager. PMO and ADMIN are ORTHOGONAL,
# joinable authorities above manager — PMO owns business governance, admin owns
# technical config; a claim can match several lists (grants are the union). These
# are also editable at runtime by an admin via PUT /api/admin/role-map.
# OIDC_ADMIN_ROLES=omni-admins,platform-admins
# OIDC_PMO_ROLES=pmo,programme-managers
# OIDC_MANAGER_ROLES=delivery-leads
# OIDC_CONTRIBUTOR_ROLES=
# OIDC_VIEWER_ROLES=stakeholders
# OIDC_DEFAULT_ROLE=contributor

# ───────────────────── business ruleset (PMO governance) ───────────────────
# Optional JSON seeds for the restrict-only business ruleset (also editable at
# runtime by the PMO). Modes: hard | warn | off.
# BUSINESS_RULE_MODES={"no-deletes":"hard","require-assignee":"warn"}
# BUSINESS_FIELD_RULES=[{"id":"require-estimate","action":"create_issue","field":"estimateHours","mode":"hard"}]

# ───────────── admin-gated database backends (raw SQL / MongoDB) ────────────
# For internally-hosted / legacy stores with no API. The sidecar holds the DB
# connection + parameterised queries; the gateway never ships raw SQL.
# SQL_SIDECAR_URL=http://sql-sidecar:8090
# SQL_SIDECAR_TOKEN=
# MONGO_SIDECAR_URL=http://mongo-sidecar:8091
# MONGO_SIDECAR_TOKEN=

# ─────────────────────────────── broker ────────────────────────────────────
# The single endpoint OmniProject brokers ALL backend reads/writes through.
# The broker is pluggable behind a published contract (docs/CONTRACT.md); n8n is
# the reference broker that ships by default (see docs/BROKER.md).
# BROKER_URL=https://n8n.example.com/webhook/omniproject
#   ^ the broker-neutral name. N8N_WEBHOOK_URL is accepted as a DEPRECATED
#     backwards-compatible alias (pre-0.2.0) if BROKER_URL is unset.
# BROKER_URLS=https://n8n-1.example.com/webhook/omniproject,https://n8n-2.example.com/webhook/omniproject
#   ^ optional: a comma-separated POOL of n8n instances. When set, the broker
#     load-balances across them (round-robin) with connection-level failover,
#     overriding BROKER_URL. For horizontal n8n scale (use n8n queue mode too).
# BROKER_PSK=                      # OPTIONAL app-layer broker encryption — a FALLBACK BELOW TLS.
#   ^ prefer TLS (https:// BROKER_URL) — it also authenticates the broker's cert.
#     Set this only when TLS is genuinely unavailable on the hop: a shared
#     high-entropy key (both ends) that AES-256-GCM-encrypts the whole request
#     envelope INCLUDING the forwarded auth token, so a packet capture sees only
#     ciphertext. Caveats: no forward secrecy, no peer auth, metadata still leaks.
#     The broker MUST implement the matching crypto (see docs/BROKER-HTTP-BINDING.md §2a).
# BACKEND_SOURCE=all               # routing hint (all | jira | openproject | …)
# CAPABILITIES=                    # pin domains (issues,scheduling,portfolio,…) to skip probing

# ───────────────── ⚠️ here-be-dragons (off by default) ─────────────────────
# MCP_WRITE_ENABLED=               # allow an AI agent to MUTATE the backend over MCP
#   ^ off unless set; even then only a contributor+ SESSION can write. See docs/MCP.md.
# RAW_API_ENABLED=                 # enable POST /api/admin/raw — the LAST-RESORT escape hatch
#   ^ admin-only, audited raw broker passthrough that BYPASSES the typed contract,
#     capability gating and the business ruleset. Leave unset unless you truly need
#     it, and turn it back off afterwards. See docs/ops/RAW-API.md.

# ───────────────────────────── AI (optional) ───────────────────────────────
# AI_PROVIDER=none                 # none | openai | anthropic | ollama | openrouter
#                                  # (the default chat provider; per-capability mapping
#                                  #  overrides it in Settings → AI providers)
# AI_MODEL=
# OLLAMA_URL=http://localhost:11434  # endpoint, not a secret — may stay here
#
# AI PROVIDER API KEYS ARE NO LONGER ENV VARS. They are entered in the admin UI
# (Settings → AI providers) and held in a secrets VAULT, not in docker.
#
# The vault storage backend is pluggable:
# VAULT_BACKEND=local              # local | hashicorp | hcp | http | aws | azure
#
# local (default) — an OmniProject-owned, doubly-encrypted file:
# VAULT_KEY=                       # base64 32 bytes; if unset, derived from SESSION_SECRET
# VAULT_FILE=                      # default <OMNI_CONFIG_DIR>/vault.json (company-wide)
# AI_PROVIDERS_FILE=               # default <OMNI_CONFIG_DIR>/ai-providers.json
#
# hashicorp / hcp — HashiCorp Vault or HCP Vault (KV v2):
# VAULT_ADDR=https://vault:8200
# VAULT_TOKEN=
# VAULT_KV_MOUNT=secret
# VAULT_KV_PATH=omni-ai-vault
#
# aws — AWS Secrets Manager (native, SigV4):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=               # optional (STS / assumed role)
# VAULT_AWS_SECRET_ID=omni-ai-vault
#
# azure — Azure Key Vault (native, AAD client credentials):
# VAULT_AZURE_VAULT_URL=https://myvault.vault.azure.net
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# VAULT_AZURE_SECRET_NAME=omni-ai-vault
#
# http — any other manager via a generic REST secrets store / external-secrets sidecar:
# VAULT_HTTP_URL=
# VAULT_HTTP_TOKEN=
#
# KMS / BYOK — wrap the vault ROOT key so the plaintext never sits in env. Supply a
# KMS-encrypted blob (VAULT_KEY_ENC); a cloud KMS unwraps it at boot:
# KMS_PROVIDER=none                # none | aws | azure | local
# VAULT_KEY_ENC=                   # base64 KMS-wrapped 32-byte vault root key
# CONFIG_KEY_ENC=                  # base64 KMS-wrapped 32-byte config-at-rest key (seals config.json etc.)
# VAULT_KMS_KEY_URL=               # azure only: https://<vault>.vault.azure.net/keys/<name>/<ver>
#                                  # (aws: *_ENC are KMS CiphertextBlobs; resolved at boot, before any sealed file is read)
#
# Provider key rotation reminder + Content-Security-Policy:
# AI_KEY_MAX_AGE_DAYS=90
# CONTENT_SECURITY_POLICY=         # full override; or CSP_REPORT_ONLY=1 / CSP_IMG_SRC=... etc.

# ───────────────────── Observability — OTLP (optional, off by default) ──────
# ALWAYS ON, no config: W3C trace context (traceparent + x-request-id, log correlation) and the
# Prometheus scrape at /api/metrics (RED metrics, broker latency, cache hit/miss, portfolio gauges).
# Set an OTLP/HTTP endpoint to ALSO export request spans AND push the metric set to a collector
# (Datadog / Jaeger / Honeycomb / Tempo / OTel Collector). The app appends /v1/traces + /v1/metrics.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4318
# OTEL_EXPORTER_OTLP_HEADERS=      # comma-separated k=v (e.g. api-key=...)
# OTEL_SERVICE_NAME=omniproject-gateway
# OTEL_METRIC_EXPORT_INTERVAL=60000  # metric push interval in ms (default 60000, floor 1000)

# ───────────────────── SCIM 2.0 provisioning (optional) ────────────────────
# Enable the IdP (Okta / Entra) to provision + deprovision users and sync groups→roles.
# Off unless SCIM_TOKEN is set. Base URL for the IdP: <host>/api/scim/v2
# SCIM_TOKEN=                       # bearer the IdP presents (long random string)
# SCIM_STATE_FILE=                  # default <OMNI_CONFIG_DIR>/scim.json (sealed at rest)

# ───────────────────── Real-time notifications + bus ───────────────────────
# NOTIFY_INGEST_SECRET=            # enables POST /api/notifications/ingest (constant-time checked)

# ─────────────────── Multi-replica / horizontal scale ──────────────────────
# REDIS_URL=                       # ONE knob for fleet fan-out. With it (+ the optional
#   ^ clients below) notifications, the admin live broker-log, AND rate-limit counters
#     become cross-replica. Without it each replica runs correctly but in isolation.
#     Install the runtime-optional clients:
#         pnpm --filter @workspace/api-server add ioredis rate-limit-redis
#     Verify via GET /api/setup/status -> scale.{notifyBus,brokerLogBus,rateLimit}="redis".
#     Falls back to per-replica (logged once) if unset or clients absent. See docs/ops/MULTI-REPLICA.md.
# REPLICA_ID=                      # optional stable label for THIS replica in the broker log
#   ^ (defaults to a random short id per process).

# ──────────────────────────────── Audit ────────────────────────────────────
# AUDIT_LEVEL=off                  # off | writes | all
# AUDIT_HTTP_URL=                  # ship NDJSON audit lines to a logging server
# AUDIT_HTTP_TOKEN=
# AUDIT_BATCH=50
# AUDIT_FLUSH_MS=2000

# ──────────────────────────── Rate limiting ────────────────────────────────
# RATE_LIMIT_DISABLED=false        # true only behind your own gateway/WAF

# ─────────────────────── Config durability (optional) ──────────────────────
# CONFIG_STORE_FILE=/data/omni-config.json   # persist environments + rollback history
# DEV_PERSIST_FILE=                # STATEFUL developer mode ONLY (ignored in production)

# ════════════════════ PREMIUM — licence VERIFICATION (every deployment) ═════
# PRE-COMMUNITY: premium is FREE to run — enforcement is dormant, not removed.
# Every premium feature is granted by default; the vars below only matter once
# enforcement is switched back on. See LICENSING.md.
# PREMIUM_ENFORCEMENT=on           # restore the paywall (default: off = all features free)
# LICENSE_PUBLIC_KEY=              # the vendor's Ed25519 public key (PEM or base64)
# LICENSE_KEY=                     # the signed licence token issued to this deployment
# LICENSE_DEV_FEATURES=            # non-prod only: "all" or a feature list; ignored in prod

# ═══════════════ PREMIUM — licence ISSUING (VENDOR instance ONLY) ═══════════
# Only on the instance that mints licences (scripts/mint-license.ts). NEVER ship
# LICENSE_PRIVATE_KEY to a customer deployment. (Payment-provider plumbing was
# removed during the pre-community period — see LICENSING.md.)
# LICENSE_PRIVATE_KEY=             # Ed25519 issuing key — mints customer licences

# ───────────── PREMIUM — branding / nomenclature / webhook seeds ────────────
# Optional seed values (also editable in-app under Settings → Premium overlay).
# BRAND_APP_NAME=
# BRAND_SHORT_NAME=
# BRAND_LOGO_URL=
# BRAND_PRIMARY_COLOR=#2563eb
# BRAND_LOGIN_HEADING=
# BRAND_FOOTER_TEXT=
# BRAND_SUPPORT_URL=
# LABEL_OVERRIDES={"nav.projects":"Engagements"}
# WEBHOOKS=[{"url":"https://hooks.example.com/omni","secret":"…","events":["*"]}]

# ───────────────────────── Dev / test / stress ─────────────────────────────
# DEMO_SCALE_PROJECTS=200
# DEMO_SCALE_ISSUES=10
# Messy-data generator (DEV MODE ONLY — inert in production). Injects real-world
# imperfections (nulls, mixed enum vocab, junk numbers/dates, missing provenance,
# id collisions…) into the read model so you can see how resilient reports and
# derivations are to dirty data. Deterministic per seed. Toggle live from the
# in-app "Messy data" dev control, or seed the boot default here:
# OMNI_MESSY_DATA=1                 # arm at boot (requires dev mode)
# OMNI_MESSY_INTENSITY=0.4          # 0..1 overall imperfection rate
# OMNI_MESSY_SEED=omni              # deterministic seed
# OMNI_MESSY_GREMLINS=nullify,dateChaos   # subset of imperfections (blank/all ⇒ all)
# STRESS_USERS=2000
# STRESS_REQS=3
# STRESS_CONCURRENCY=100
# STRESS_MAX_ERROR_RATE=0.01
# OMNI_API_BASE=http://localhost:5000
# OPENPROJECT_LIVE_URL=            # live integration cert (skipped if unset)
# OPENPROJECT_TOKEN=

# ═══════════ DOCKER COMPOSE — local standalone stack (docker-compose.standalone.yml)
# These back the bundled Traefik + Authentik + n8n + Ollama stack. Compose
# FAILS FAST (won't start) if a required one is missing — that's intentional.
# Full bootstrap (mkcert TLS, /etc/hosts, Authentik app): docs/DEPLOY-LOCAL.md
#
# Required:
# SESSION_SECRET=                  # long random string; signs the session cookie
# OIDC_CLIENT_SECRET=              # the "omniproject" OIDC client secret from Authentik
# AUTHENTIK_PG_PASSWORD=           # Authentik's Postgres password
# AUTHENTIK_SECRET_KEY=            # Authentik secret key (50+ random chars)
#
# Traefik dashboard auth (htpasswd, bcrypt). Generate the line with:
#   htpasswd -nbB admin 'your-password'      ->  admin:$2y$05$abc...
# IMPORTANT: in a .env FILE, Compose interpolates values, so EVERY '$' must be
#    DOUBLED to '$$'. The single-$ form only works when exported in your shell.
#    So paste it here with doubled $$, e.g.:
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$abc...defGHIjklMNOpqrSTUvwx
#    (or keep it OUT of .env and `export TRAEFIK_DASHBOARD_AUTH='admin:$2y$05$...'`
#     with a single $ in your shell before running compose.)
#
# Optional (have sensible defaults): OIDC_CLIENT_ID=omniproject, AI_PROVIDER,
# AI_MODEL. (AI provider API keys are entered in the UI → encrypted vault, not here.)

# ═══════════ DOCKER COMPOSE — enterprise / BYO profile (docker-compose.enterprise.yml)
# Required (compose fails fast without them):
# PUBLIC_URL=https://omni.example.com   # external HTTPS origin (Secure cookies need https)
# OIDC_ISSUER_URL=https://your-idp.example.com/...   # your existing IdP (https)
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# SESSION_SECRET=
# Optional: BROKER_URL, N8N_PUBLIC_URL, PLANE_INSTANCE_URL, OPENPROJECT_INSTANCE_URL, AI_*
