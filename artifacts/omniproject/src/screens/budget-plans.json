      "source": { "url": "/api/budget-plans/rows?groupBy=year&metric=sum:amount" }
    },
    {
      "id": "budget-by-year",
      "kind": "table",
      "title": "Budget by year",
      "span": 6,
      "source": { "url": "/api/budget-plans/rows?groupBy=year&metric=sum:amount" }
    },
    {
      "id": "budget-by-project",
      "kind": "table",
      "title": "Budget by project",
      "span": 6,
      "source": { "url": "/api/budget-plans/rows?groupBy=projectId&metric=sum:amount" }
    },
    {
      "id": "budget-all-periods",
      "kind": "table",
      "title": "All planned periods",
      "span": 12,
      "source": { "url": "/api/budget-plans/rows" }
    }
  ]
