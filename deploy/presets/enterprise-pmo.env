# Enterprise PMO — docker-compose.enterprise.yml (BYO SSO + backends + AI)
SETTINGS_PRESET=enterprise-pmo
AI_PROVIDER=none            # keys go in Settings → AI providers (encrypted vault)
# ── required secrets (fill these in) ─────────────────────────────────────────
PUBLIC_URL=                 # external https origin you serve behind
OIDC_ISSUER_URL=            # your IdP issuer (https)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
SESSION_SECRET=             # long random string
