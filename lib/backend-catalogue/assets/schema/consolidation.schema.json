{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omniproject.dev/assets/consolidation.schema.json",
  "title": "OmniProject consolidation spec",
  "description": "A group-consolidation spec: which per-project measures to sum, the derived metrics, and the row sort. One file per spec under assets/consolidations/<id>.json. Run by the consolidateByGroup engine.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "measures", "derived", "sort"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "measures": {
      "type": "array",
      "description": "How each measure is extracted from a group's items (field + aggregation), then FX-converted.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "agg", "field"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-zA-Z0-9]+$" },
          "agg": { "type": "string", "enum": ["sum", "weightedSum"] },
          "field": { "type": "string", "pattern": "^[a-zA-Z0-9_]+$" },
          "weightField": { "type": "string", "pattern": "^[a-zA-Z0-9_]+$" },
          "weightScale": { "type": "number" },
          "weightDefault": { "type": "number" },
          "weightMax": { "type": "number" }
        }
      }
    },
    "derived": {
      "type": "array",
      "description": "Derived metrics computed from the raw measure sums by a named, closed-vocabulary operation.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "op", "a", "b"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-zA-Z0-9]+$" },
          "op": { "type": "string", "enum": ["diff", "diffFloor0", "ratioPct", "ratioOrNull"] },
          "a": { "type": "string", "pattern": "^[a-zA-Z0-9]+$" },
          "b": { "type": "string", "pattern": "^[a-zA-Z0-9]+$" }
        }
      }
    },
    "sort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "dir"],
      "properties": {
        "key": { "type": "string", "pattern": "^[a-zA-Z0-9]+$" },
        "dir": { "type": "string", "enum": ["asc", "desc"] }
      }
    }
  }
}
