        260
      ],
      "credentials": {
        "oAuth2Api": {
          "id": "",
          "name": "SAP S/4HANA (PS/PPM Financials — read-only) account"
        }
      },
      "notes": "Enterprise Project + WBS element master data (structure and org assignment) via the same API_ENTERPRISE_PROJECT_SRV service the 'sap' (WBS read/write) backend uses, but read-only and narrowed with $select to only the financial dimensions this connector cares about: the controlling area, company code and responsible cost center that scope the cost data in list_issues. No cost AMOUNTS live on this entity — see list_issues / notes for where actuals and budget actually come from."
    },
    {
      "parameters": {
        "jsCode": "// Declare which domains your wired backend(s) can populate. Edit to match.\nreturn [{ json: { success: true, data: {\"baseline\":false,\"blockers\":false,\"financials\":true,\"history\":false,\"issues\":true,\"portfolio\":true,\"raid\":false,\"resources\":false,\"scheduling\":false} } }];"
      },
