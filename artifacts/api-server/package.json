{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "sidecar": "tsx src/broker/reference-sidecar.ts",
    "broker:send": "tsx src/broker/send-cli.ts",
    "broker:replay": "tsx src/broker/replay-cli.ts",
    "smoke": "tsx --test src/broker/smoke.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "c8 tsx --test \"src/**/*.test.ts\"",
    "test:integration:live": "tsx --test src/__tests__/live-endpoints.integration.test.ts",
    "bench": "tsx ./src/bench/run.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/backend-catalogue": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jose": "^6.1.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.14.0",
    "pino-http": "^11.0.0",
    "undici": "8.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "c8": "^11.0.0",
    "esbuild": "0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "4.2.0",
    "tsx": "catalog:"
  }
}
