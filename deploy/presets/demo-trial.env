# Demo / Trial — docker-compose.standalone.yml (full local stack + demo data)
SETTINGS_PRESET=demo-trial
AI_PROVIDER=none            # standalone bundles Ollama; set 'ollama' to use it
# standalone needs its bootstrap secrets — see docker-compose.standalone.yml header:
SESSION_SECRET=
OIDC_CLIENT_SECRET=
AUTHENTIK_PG_PASSWORD=
AUTHENTIK_SECRET_KEY=
TRAEFIK_DASHBOARD_AUTH=
